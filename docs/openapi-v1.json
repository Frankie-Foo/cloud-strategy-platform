      "PaperCloseOrderEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "request"],
        "properties": {
          "kind": {"type": "string", "const": "close"},
          "request": {"$ref": "#/components/schemas/PaperCloseOrderRequest"}
        }
      },
      "PaperOrderEnvelope": {
        "oneOf": [
          {"$ref": "#/components/schemas/PaperEntryOrderEnvelope"},
          {"$ref": "#/components/schemas/PaperCloseOrderEnvelope"}
        ],
        "discriminator": {
          "propertyName": "kind",
          "mapping": {
            "entry": "#/components/schemas/PaperEntryOrderEnvelope",
            "close": "#/components/schemas/PaperCloseOrderEnvelope"
          }
        }
      },
      "CancelPaperOrderResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["api_version", "cancelled"],
        "properties": {
