      "PaperEntryOrderRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["client_order_id", "symbol", "qty", "take_profit_price", "stop_loss_price"],
        "properties": {
          "client_order_id": {"type": "string", "minLength": 1, "maxLength": 128},
          "symbol": {"$ref": "#/components/schemas/Symbol"},
          "qty": {"type": "integer", "minimum": 1},
          "side": {"type": "string", "const": "buy", "default": "buy"},
          "order_type": {"type": "string", "enum": ["market", "limit"], "default": "market"},
          "time_in_force": {"type": "string", "const": "day", "default": "day"},
          "extended_hours": {"type": "boolean", "const": false, "default": false},
          "limit_price": {"type": ["string", "null"], "description": "Required and non-null for limit orders; omit it or use null for market orders."},
          "take_profit_price": {"type": "string", "minLength": 1},
          "stop_loss_price": {"type": "string", "minLength": 1}
        }
      },
      "PaperCloseOrderRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["client_order_id", "symbol", "qty"],
        "properties": {
          "client_order_id": {"type": "string", "minLength": 1, "maxLength": 128},
          "symbol": {"$ref": "#/components/schemas/Symbol"},
          "qty": {"type": "integer", "minimum": 1},
          "side": {"type": "string", "const": "sell", "default": "sell"},
          "order_type": {"type": "string", "const": "market", "default": "market"},
          "time_in_force": {"type": "string", "const": "day", "default": "day"},
          "extended_hours": {"type": "boolean", "const": false, "default": false}
        }
      },
      "PaperEntryOrderEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "request"],
